{
  "name": "norcal-camila-ops",
  "version": "1.0.0",
  "private": true,
  "description": "Camila Ops — nightly Places discover + hourly cold send + send log",
  "type": "module",
  "scripts": {
    "status": "node run.js status",
    "discover": "node run.js discover --industry tow_trucks",
    "discover:tow": "node run.js discover --industry tow_trucks",
